# ============================================================================
# Yunta-Agro — Configuración Web3 / Lnet (Hyperledger Besu)   [FASE 3 — PLANTILLA]
# ----------------------------------------------------------------------------
# NADA de esto está activo en el MVP fiat actual. Estas variables quedan listas
# para rellenar cuando Lnet entregue el acceso al nodo (Fase 0 del audit).
# El módulo que las lee y valida es: src/config/lnet.config.ts
#
# Activación: copiar lo necesario a `.env`, instalar ethers (npm i ethers) y
# seguir el checklist de ../contracts/README.md. Mientras LNET_ENABLED=false
# (default), Yunta NO intenta conectar a ninguna blockchain.
# ============================================================================

# ── Interruptor maestro ─────────────────────────────────────────────────────
# false (default): el MVP corre 100% fiat, sin tocar la blockchain.
# true: el bootstrap valida la config Lnet y (en Fase 3) arranca el listener.
LNET_ENABLED=false

# ── Red Lnet / Besu ─────────────────────────────────────────────────────────
# RPC del nodo escritor (writer node) de Lnet sobre el que firmamos/leemos.
# Lnet usa un modelo de gas no-monetario vía Relay Hub; no se paga gas en cripto.
LNET_RPC_URL=__PENDIENTE_RPC_WRITER_NODE__

# RPC de la Layer-2 EVM donde vive el seguro paramétrico (rollup sobre Besu).
# Lo consume el listener (parametricInsurance.listener.ts).
LNET_L2_RPC_URL=__PENDIENTE_RPC_L2__

# Chain ID de la red permisionada (entero). Lo entrega Lnet al registrar el nodo.
LNET_CHAIN_ID=__PENDIENTE_CHAIN_ID__

# ── Modelo de gas no-monetario (Relay Hub) ──────────────────────────────────
# Dirección del contrato Relay Hub de Lnet que patrocina el gas de las tx.
RELAY_HUB_ADDRESS=0x0000000000000000000000000000000000000000

# Clave privada del writer node autorizado por Lnet para firmar transacciones.
# ⚠️ SECRETO. Nunca commitear. En producción usar gestor de secretos / KMS.
WRITER_NODE_PRIVATE_KEY=__PENDIENTE_LLAVE_PRIVADA_WRITER__

# ── Contrato del Seguro Paramétrico (ParametricInsurance.sol) ────────────────
# Dirección desplegada en la L2. ABI en: ../contracts/abi/ParametricInsurance.json
PARAMETRIC_INSURANCE_ADDRESS=0x0000000000000000000000000000000000000000

# ── Oráculo climático (SENAMHI vía Chainlink / oráculo del consorcio Lnet) ───
# Alimenta al contrato con datos de lluvia/sequía que disparan PayoutTriggered.
ORACLE_ADDRESS=0x0000000000000000000000000000000000000000
SENAMHI_API_URL=__PENDIENTE_API_SENAMHI__
SENAMHI_API_KEY=__PENDIENTE_API_KEY_SENAMHI__

# ── Identidad descentralizada (LACChain ID — DIDs/VCs W3C) ───────────────────
# Para emitir las credenciales verificables (tokens de certificación tributaria).
LACCHAIN_DID_REGISTRY=0x0000000000000000000000000000000000000000
LACCHAIN_ISSUER_DID=__PENDIENTE_DID_DEL_EMISOR__
