# Conexión a la base de datos PostgreSQL.
# Desarrollo local con Docker (docker compose up -d en la raíz):
DATABASE_URL=postgresql://yunta:yunta_dev_password@localhost:5432/yunta?schema=public
# En producción usar un Postgres gestionado (Neon, Supabase, RDS, Cloud SQL) y
# nunca commitear credenciales reales — esto va en el .env local / secret manager.

# Obligatorio en producción — firma y verifica todos los JWT de sesión.
# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia-esto-en-produccion

# Obligatorio en producción — valida la firma HMAC de los webhooks interoperables entrantes.
# Debe coincidir con el secreto configurado en el proveedor (e.g. BIM, Yapita).
WEBHOOK_SECRET=cambia-esto-en-produccion

# Origen permitido para CORS en producción (e.g. https://app.yunta.pe).
# En desarrollo no se necesita — se permite cualquier localhost automáticamente.
CORS_ORIGIN=https://tu-dominio.com

# Puerto del servidor (opcional, default: 3000).
PORT=3000

# Entorno de ejecución. En producción siempre debe ser "production".
NODE_ENV=development

# ── Web3 / Lnet (Fase 3) ────────────────────────────────────────────────────
# La conexión a la blockchain de Lnet (Besu) tiene su propia plantilla con
# TODAS sus variables: .env.web3.example. Por defecto está deshabilitada
# (LNET_ENABLED=false) y el MVP corre 100% fiat. No necesitas nada de esto
# para operar el MVP. Config y validación: src/config/lnet.config.ts
# LNET_ENABLED=false
