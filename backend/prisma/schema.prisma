// ============================================================================
// Yunta — Esquema de base de datos (Prisma)
// Developed by Marketnauta
// ============================================================================

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// JTIs de JWT revocados (logout). Persistente para que la revocación SOBREVIVA a
// reinicios del servidor (corrige el riesgo P0-3: blocklist en memoria volátil).
// expiresAt = expiración del token: tras esa fecha el JWT ya no es válido por sí
// mismo, así que la fila puede purgarse sin reintroducir el token.
model RevokedToken {
  jti       String   @id
  expiresAt DateTime
  revokedAt DateTime @default(now())

  @@index([expiresAt])
}

model MerchantProfile {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique @default(uuid())
  businessName String
  ownerName    String
  ruc          String?  // 11 digits
  dni          String?  // 8 digits
  phoneNumber  String   @unique
  email        String?  @unique
  pin          String?  // bcrypt hash of 4-digit PIN
  status       String   @default("Active") // Active, Suspended, KYC_Pending
  saasTier     String   @default("Free") // Free, Pro
  mdrRate      Float    @default(0.00)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  wallet       Wallet?
  products     Product[]
  creditLine   CreditLine?
  producer     ProducerProfile?
  transactionsAsSender   Transaction[] @relation("SenderTransactions")
  transactionsAsReceiver Transaction[] @relation("ReceiverTransactions")
}

model Wallet {
  id         Int      @id @default(autoincrement())
  merchantId Int      @unique
  balance    Float    @default(0.00)
  currency   String   @default("PEN")
  updatedAt  DateTime @updatedAt

  merchant   MerchantProfile @relation(fields: [merchantId], references: [id])
}

model Transaction {
  id                  Int      @id @default(autoincrement())
  txSignature         String   @unique
  senderPhone         String?
  receiverPhone       String?
  amount              Float
  fee                 Float    @default(0.00)
  type                String   // P2P, P2B, CICO_Deposit, CICO_Withdrawal, Loan_Disbursement, Loan_Repayment
  interoperableSource String   // Yape, Plin, BCP, BBVA, Interbank, Yunta_Internal
  status              String   @default("Initiated") // Initiated, Pending_Settlement, Settled, Failed
  createdAt           DateTime @default(now())
  settledAt           DateTime?

  senderMerchant   MerchantProfile? @relation("SenderTransactions", fields: [senderPhone], references: [phoneNumber])
  receiverMerchant MerchantProfile? @relation("ReceiverTransactions", fields: [receiverPhone], references: [phoneNumber])

  @@index([senderPhone])
  @@index([receiverPhone])
}

model Product {
  id            Int      @id @default(autoincrement())
  merchantId    Int
  name          String
  price         Float
  stockQuantity Int      @default(0)
  sku           String?

  merchant      MerchantProfile @relation(fields: [merchantId], references: [id])
  sales         SalesLedger[]
}

model SalesLedger {
  id         Int      @id @default(autoincrement())
  productId  Int
  quantity   Int
  totalAmount Float
  recordedAt DateTime @default(now())

  product    Product  @relation(fields: [productId], references: [id])
}

model CreditLine {
  id                      Int      @id @default(autoincrement())
  merchantId              Int      @unique
  creditLimit             Float    @default(0.00)
  utilizedAmount          Float    @default(0.00)
  interestRateEffective   Float    // TEA
  alternativeScore        Int      @default(0) // 0-1000
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  merchant                MerchantProfile   @relation(fields: [merchantId], references: [id])
  installments            LoanInstallment[]
}

model LoanInstallment {
  id           Int        @id @default(autoincrement())
  creditLineId Int
  amount       Float
  dueDate      DateTime
  status       String     @default("Unpaid") // Unpaid, Paid, Overdue

  creditLine   CreditLine @relation(fields: [creditLineId], references: [id])
}

// ============================================================================
// Yunta-Agro — Modelos agronómicos (fusionados desde schema.agro.prisma)
// ============================================================================

model ProducerProfile {
  id              Int      @id @default(autoincrement())
  merchantId      Int      @unique
  dni             String   @unique
  ppaVerified     Boolean  @default(false)
  ppaCode         String?
  hectares        Float    @default(0)
  region          String?
  gpsLat          Float?
  gpsLng          Float?
  mainCrop        String?

  // ── Solución 7: Identidad PPA completa (capa de identidad soberana) ────────
  // Ancla KYC del Padrón de Productores Agrarios (>2.1M registros georreferenciados).
  // En Fase 3 estos campos respaldan un DID/VC (SSI); hoy viven en Postgres.
  agroDigitalId   String?  @unique // ID único del productor en AgroDigital/PPA
  ppaIngestedAt   DateTime?         // cuándo se ingestó la identidad georreferenciada
  identityHash    String?           // SHA-256 del snapshot de identidad (precursor de VC)
  legalParcelCount Int     @default(0) // nº de parcelas declaradas en el padrón
  verifiedHectares Float  @default(0)  // superficie verificada (suma de parcelas)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  merchant        MerchantProfile @relation(fields: [merchantId], references: [id])
  campaigns       AgroCampaign[]
  subsidies       SubsidyDisbursement[]
  policies        InsurancePolicy[]
  certifications  CertificationToken[]
  parcels         AgroParcel[]
  riskAlerts      RiskAlert[]
}

// ── Solución 7: parcelas georreferenciadas del PPA (un productor, N parcelas) ─
model AgroParcel {
  id            Int      @id @default(autoincrement())
  producerId    Int
  parcelCode    String   // código catastral / de padrón de la parcela
  hectares      Float
  gpsLat        Float
  gpsLng        Float
  district      String?
  province      String?
  region        String?
  landTenure    String   @default("Owner") // Owner, Possessor, Communal
  createdAt     DateTime @default(now())

  producer      ProducerProfile @relation(fields: [producerId], references: [id])

  @@unique([producerId, parcelCode])
  @@index([producerId])
}

model AgroCampaign {
  id               Int       @id @default(autoincrement())
  producerId       Int
  crop             String
  season           String
  inputCostTotal   Float     @default(0)
  harvestWeightKg  Float     @default(0)
  buyerName        String?
  salePricePerKg   Float?
  status           String    @default("Planted") // Planted, Growing, Harvested, Sold
  startedAt        DateTime  @default(now())
  harvestedAt      DateTime?

  producer         ProducerProfile @relation(fields: [producerId], references: [id])
  inputs           CampaignInput[]
  certification    CertificationToken?
  telemetry        IoTSensorTelemetry[]
  alerts           AgroAlert[]
  droneScans       DroneTelemetryCache[]

  @@index([producerId])
}

model CampaignInput {
  id           Int      @id @default(autoincrement())
  campaignId   Int
  type         String   // Seed, Fertilizer, Labor, Pesticide, BioFertilizer
  description  String
  amount       Float
  purchasedAt  DateTime @default(now())
  paidWith     String   @default("Subsidy") // Subsidy, Credit, Own

  // ── Solución 10: biotecnología / mejoramiento genético ────────────────────
  // Clase de semilla declarada en el Cashbook. "CertifiedImproved" = variedad
  // mejorada (tolerante a estrés térmico, resistente a roya, clon bajo cadmio),
  // que reduce el riesgo de pérdida de cosecha → bonifica el score y baja la TCEA.
  seedClass    String?  // Conventional, CertifiedImproved, RustResistant, LowCadmium, HeatTolerant
  geneticTrait String?  // marcador/rasgo declarado (ej. "Resistente a roya — INIA")

  campaign     AgroCampaign @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
}

model CertificationToken {
  id              Int      @id @default(autoincrement())
  campaignId      Int      @unique
  producerId      Int
  productKg       Float
  buyerRuc        String
  taxYear         Int
  deductiblePct   Float    @default(0.25)

  // ── "Pasaporte digital" EUDR / trazabilidad (Capa Precursora Web2) ─────────
  // vcHash es un SHA-256 sobre el snapshot inmutable de la cosecha (GPS + PPA +
  // campaña + producto). Imita la inmutabilidad de un token on-chain en una BD
  // relacional: cualquier alteración de los datos certificados rompe el hash.
  // Cuando LNET entregue accesos, este mismo hash se anclará en cadena (chainTxHash).
  vcHash          String   @unique  // SHA-256 hex del payload certificado
  certUuid        String   @unique @default(uuid()) // identificador público del pasaporte
  gpsLat          Float?   // geolocalización del lote (requisito EUDR de deforestación cero)
  gpsLng          Float?
  region          String?
  cropType        String?
  ppaCode         String?  // validación del Padrón de Productores Agrarios
  certifiedPayload String? // snapshot JSON exacto que produjo el hash (auditable)
  chainTxHash     String?  // se rellena al anclar en LNET (Fase 3)
  status          String   @default("Issued") // Issued, Presented_SUNAT, Validated, AnchoredOnChain
  issuedAt        DateTime @default(now())

  campaign        AgroCampaign    @relation(fields: [campaignId], references: [id])
  producer        ProducerProfile @relation(fields: [producerId], references: [id])

  @@index([producerId])
  @@index([buyerRuc])
  @@index([certUuid])
}

model SubsidyDisbursement {
  id            Int      @id @default(autoincrement())
  producerId    Int
  program       String   // FertiBono, AgroIdeas, etc.
  amount        Float
  spentOnInputs Float    @default(0)
  status        String   @default("Disbursed") // Disbursed, PartiallySpent, Reconciled
  disbursedAt   DateTime @default(now())

  producer      ProducerProfile @relation(fields: [producerId], references: [id])

  @@index([producerId])
}

model InsurancePolicy {
  id                  Int       @id @default(autoincrement())
  producerId          Int
  // Identificador de póliza. Hoy lo genera el backend (UUID); cuando LNET esté
  // listo, será el id de la póliza on-chain. Mantener el nombre evita migrar IDs.
  chainPolicyId       String    @unique
  crop                String
  gpsLat              Float
  gpsLng              Float

  // ── Parámetros del disparador (Capa Precursora — evaluados off-chain) ──────
  rainThresholdMm     Float     // sequía: lluvia acumulada por debajo de este umbral
  tempMaxThreshold    Float?    // estrés térmico / El Niño: temp. máxima anómala (°C)
  tempMinThreshold    Float?    // heladas: temp. mínima anómala (°C)
  stationKey          String    @default("default") // estación meteo de referencia (oráculo)

  coverageAmount      Float     // indemnización en soles
  premium             Float
  periodStart         DateTime
  periodEnd           DateTime
  status              String    @default("Active") // Active, Triggered, Expired, PaidOut
  triggeredEventType  String?   // Drought, HeatStress_ElNino, Frost
  triggeredAt         DateTime?
  lastEvaluatedAt     DateTime? // última vez que el motor paramétrico la revisó
  payoutTxId          Int?      // transacción de liquidación en el ledger
  createdAt           DateTime  @default(now())

  producer            ProducerProfile @relation(fields: [producerId], references: [id])

  @@index([producerId])
  @@index([status])
  @@index([stationKey])
}

model OfflineSignedTx {
  id              Int      @id @default(autoincrement())
  idempotencyKey  String   @unique
  producerPhone   String
  payload         String
  signature       String
  nonce           Int
  expiresAt       DateTime
  receivedVia     String   @default("Sync") // Sync, USSD, MeshBLE
  status          String   @default("Pending") // Pending, Settled, Rejected_Expired, Rejected_Signature
  receivedAt      DateTime @default(now())
  settledAt       DateTime?

  @@index([producerPhone])
  @@index([status])
}

// ============================================================================
// Yunta-Agro — Capa Precursora AgTech (Web2 / off-chain)
// Developed by Marketnauta
// ----------------------------------------------------------------------------
// Modelos que simulan la descentralización (oráculo, telemetría, alertas)
// usando solo PostgreSQL + node-cron. Diseñados para que la migración a smart
// contracts (LNET) sea un reemplazo de implementación, no un rediseño de datos.
// ============================================================================

// ── Solución 1: Telemetría IoT / estaciones agrometeorológicas ──────────────
// Recibe ráfagas M2M (humedad de suelo, temperatura) ligadas a una campaña.
model IoTSensorTelemetry {
  id              Int      @id @default(autoincrement())
  campaignId      Int
  deviceId        String   // identificador del nodo/sensor físico
  soilMoisturePct Float?   // % de humedad volumétrica del suelo
  soilTempC       Float?   // temperatura del suelo (°C)
  airTempC        Float?   // temperatura ambiente (°C)
  humidityPct     Float?   // humedad relativa del aire (%)
  batteryPct      Float?   // estado del nodo (telemetría de salud)
  recordedAt      DateTime @default(now()) // timestamp del sensor (puede venir del payload)
  ingestedAt      DateTime @default(now()) // timestamp de ingesta en el backend

  campaign        AgroCampaign @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
  @@index([deviceId])
  @@index([recordedAt])
}

// Alertas derivadas de telemetría (estrés hídrico/térmico) o del motor de seguros.
model AgroAlert {
  id            Int      @id @default(autoincrement())
  campaignId    Int
  type          String   // WaterStress, HeatStress, FrostRisk, DeviceOffline, InsurancePayout
  severity      String   @default("Warning") // Info, Warning, Critical
  message       String
  metricValue   Float?   // valor que disparó la alerta (ej. humedad 11.5%)
  threshold     Float?   // umbral cruzado
  acknowledged  Boolean  @default(false)
  createdAt     DateTime @default(now())

  campaign      AgroCampaign @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
  @@index([type])
  @@index([acknowledged])
}

// ── Solución 2: Oráculo climático centralizado (off-chain) ──────────────────
// Caché diario de datos meteorológicos (SENAMHI/NOAA simulado). Es la "fuente de
// verdad inmutable a nivel de BD" que consumen los seguros paramétricos.
// La unicidad (stationKey + date) garantiza un único registro autoritativo por día.
model OracleWeatherDataCache {
  id              Int      @id @default(autoincrement())
  stationKey      String   // estación/zona de referencia (ej. "cusco-quispicanchi")
  date            DateTime // día calendario (00:00) al que corresponde la lectura
  tempMaxC        Float
  tempMinC        Float
  tempAvgC        Float
  precipitationMm Float
  humidityPct     Float?
  source          String   @default("SENAMHI_SIM") // proveedor del dato
  payloadHash     String   // SHA-256 del payload crudo (integridad / "inmutabilidad")
  fetchedAt       DateTime @default(now())

  @@unique([stationKey, date]) // un registro autoritativo por estación y día
  @@index([stationKey])
  @@index([date])
}

// ============================================================================
// Yunta-Agro — Capa Precursora (Soluciones 6–10). Developed by Marketnauta
// ============================================================================

// ── Solución 9: agricultura de precisión — caché de telemetría de drones ─────
// Payloads de drones multiespectrales / visión computacional de terceros.
model DroneTelemetryCache {
  id              Int      @id @default(autoincrement())
  campaignId      Int
  provider        String   // proveedor del vuelo/análisis (ej. "AgriVision")
  flightId        String   // identificador del vuelo
  ndvi            Float?   // Índice de Vegetación de Diferencia Normalizada (0–1)
  ndre            Float?   // Normalized Difference Red Edge (estrés/clorofila)
  canopyTempC     Float?   // temperatura del dosel (estrés térmico)
  thermalStress   Boolean  @default(false) // el análisis reporta estrés térmico
  diseaseDetected Boolean  @default(false) // detección de enfermedad (roya, etc.)
  diseaseLabel    String?  // etiqueta de la enfermedad/plaga detectada
  fruitMaturityPct Float?  // % de madurez de fruto (ej. arándanos)
  affectedAreaPct Float?   // % del área con anomalía
  payloadHash     String   // SHA-256 del payload crudo (integridad)
  capturedAt      DateTime // timestamp del vuelo
  ingestedAt      DateTime @default(now())

  campaign        AgroCampaign @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
  @@index([flightId])
}

// Alertas de RIESGO a nivel de PRODUCTOR (no de campaña): consolidan señales de
// drones, clima y telemetría para ajustar dinámicamente la evaluación crediticia.
model RiskAlert {
  id            Int      @id @default(autoincrement())
  producerId    Int
  source        String   // Drone, Weather, IoT, Manual
  category      String   // ThermalStress, Disease, Drought, Flood
  severity      String   @default("Warning") // Info, Warning, Critical
  message       String
  riskDelta     Int      @default(0) // impacto temporal en el score (ej. -40)
  resolved      Boolean  @default(false)
  createdAt     DateTime @default(now())

  producer      ProducerProfile @relation(fields: [producerId], references: [id])

  @@index([producerId])
  @@index([resolved])
}

// ── Solución 6: liquidación de subsidios gubernamentales vía TAPP (BCRP) ─────
// Registro de desembolsos fiduciarios (Fertiabono, etc.) recibidos por el riel
// interoperable TAPP y liquidados en la billetera del productor.
model GovSubsidyDisbursement {
  id              Int      @id @default(autoincrement())
  programCode     String   // FERTIABONO, AGROIDEAS, etc.
  beneficiaryPhone String  // teléfono del productor beneficiario
  beneficiaryDni  String?  // DNI (conciliación con el PPA)
  amount          Float    // monto en soles
  rail            String   @default("TAPP") // riel de pago (TAPP/BCRP)
  bcrpReference   String   @unique // referencia única del BCRP (idempotencia)
  status          String   @default("Settled") // Settled, Failed
  ledgerTxId      Int?     // transacción de liquidación en el ledger
  disbursedAt     DateTime @default(now())

  @@index([beneficiaryPhone])
  @@index([programCode])
}
